NEXT_PUBLIC_SITE_URL=https://ciroai.com

# Email backend toggle. Set to "firebase" once env vars below are filled.
EMAIL_BACKEND=mock

# Optional Firebase (Firestore) backend.
# When set, the marketing site reads stories live from `stories/` (only
# docs with `published: true`) and writes waitlist submissions to
# `ciro_waitlist`. Leave blank to fall back to the local catalog.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Shared secret for /api/revalidate. Set this and call the endpoint from
# a Firebase Cloud Function on each story write to flush ISR caches
# instantly instead of waiting for the 60s window.
REVALIDATE_SECRET=

# --- Admin dashboard (/admin) -----------------------------------------------
# Firebase Web SDK config — used by the browser sign-in form on /admin/login.
# Get these from Firebase Console -> Project settings -> "Your apps" -> Web
# app -> Config. Adding a Web app to the project is a one-time step if you
# only have iOS/Android apps configured today. These values are public by
# Firebase's design; authorisation still happens server-side via roles/{uid}.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Maps JavaScript API key for the /admin/world map editor. Create a
# NEW key in Google Cloud Console (don't reuse the iOS/Android Maps keys —
# those are restricted to mobile bundle IDs):
#   1. APIs & Services -> Credentials -> Create credentials -> API key
#   2. Restrict the key to: HTTP referrers -> https://ciroai.com/*
#   3. API restrictions -> select "Maps JavaScript API" (and Places +
#      Geocoding if you'll use them later)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# App store links (used by hero CTAs)
NEXT_PUBLIC_IOS_URL=https://apps.apple.com/app/ciro
NEXT_PUBLIC_ANDROID_URL=https://play.google.com/store/apps/details?id=travel.ciro
